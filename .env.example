# RAG Lab — Environment Configuration
# Copy this file to .env and fill in your values.

# Environment: 'development' or 'production'
# In production, JWT_SECRET below MUST be set (the app will refuse to start otherwise).
APP_ENV=development

# JWT secret
# In dev: leave commented and a persistent secret is auto-created at data/.jwt_secret.
# In prod: REQUIRED. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=your-secret-here

# CORS — comma-separated allowed origins. Add your production domain here.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Ollama Cloud (optional — get a key at https://ollama.com/settings/keys)
# OLLAMA_API_KEY=your-key-here
# Request timeouts in seconds (connect / read). Defaults: 10s connect, 1800s read.
# OLLAMA_CONNECT_TIMEOUT=10
# OLLAMA_READ_TIMEOUT=1800

# Mem0 memory (optional — uses Ollama for LLM + embeddings)
MEM0_LLM_MODEL=gemma3:4b
MEM0_EMBED_MODEL=nomic-embed-text:latest
MEM0_CHROMA_PATH=./data/mem0_chroma

# HuggingFace (optional — set to 1 for offline mode)
HF_HUB_OFFLINE=0
