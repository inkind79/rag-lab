# RAG Lab — Environment Configuration
# Copy this file to .env and fill in your values.

# JWT secret (optional — a random one is generated if not set)
# To set a persistent secret: python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=your-secret-here

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Ollama Cloud (optional — get a key at https://ollama.com/settings/keys)
# OLLAMA_API_KEY=your-key-here

# Mem0 memory (optional — uses Ollama for LLM + embeddings)
MEM0_LLM_MODEL=gemma3:4b
MEM0_EMBED_MODEL=nomic-embed-text:latest
MEM0_CHROMA_PATH=./data/mem0_chroma

# HuggingFace (optional — set to 1 for offline mode)
HF_HUB_OFFLINE=0

# Sentry error tracking (optional — leave unset to disable; nothing ships externally without it).
# Backend uses sentry-sdk[fastapi]; frontend reads PUBLIC_SENTRY_DSN at build time.
# SENTRY_DSN=https://your-public-key@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=
# SENTRY_TRACES_SAMPLE_RATE=0.0
# SENTRY_SEND_PII=false
# Frontend DSN (must use PUBLIC_ prefix so Vite inlines it into the browser bundle):
# PUBLIC_SENTRY_DSN=https://your-public-key@o0.ingest.sentry.io/0
# PUBLIC_SENTRY_ENVIRONMENT=production
# PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
